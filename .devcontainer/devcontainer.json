{
  "name": "DIGGS Hackathon 2026",
  "build": {
    "context": "..",
    "dockerfile": "../dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.widgetScriptSources": ["jsdelivr.com", "unpkg.com"],
        "notebook.cellToolbarLocation": {
          "default": "right",
          "jupyter-notebook": "left"
        }
      }
    }
  },

  "postCreateCommand": "python -m ipykernel install --user --name=diggs-hackathon --display-name='DIGGS Hackathon (Python 3.11)'",

  "forwardPorts": [8888],

  "portsAttributes": {
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "notify"
    }
  }
}
